# Backend Environment Variables Template
# Copy this file to .env and fill in your real values.
# DO NOT commit the .env file — it is in .gitignore.

MONGO_URI=mongodb://localhost:27017/hotel_reservation
JWT_SECRET=<replace-with-a-random-256-bit-secret>
JWT_EXPIRATION=86400000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: generate an App Password at myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email@gmail.com>
MAIL_PASSWORD=<your-16-char-app-password>
MAIL_FROM=<your-email@gmail.com>
